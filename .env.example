# Copy this file to .env and fill in the values.
# Never commit .env — only commit this file.

# ---- Server ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---- Database ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp_dev

# Test database (used by Vitest)
DATABASE_URL_TEST=postgresql://postgres:password@localhost:5432/myapp_test

# ---- Auth ----
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# ---- CORS ----
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173
